{
  "ci": {
    "collect": {
      "settings": {
        "preset": "desktop",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"],
        "skipAudits": ["redirects"]
      }
    },
    "assert": {
      "assertions": {
        "uses-rel-preconnect": "warn",
        "meta-description": "error",
        "document-title": "error",
        "html-has-lang": "error",
        "html-lang-valid": "error",
        "meta-viewport": "error",
        "heading-order": "error",
        "link-name": "error",
        "image-alt": "error",
        "uses-optimized-images": "warn",
        "uses-text-compression": "warn",
        "uses-responsive-images": "warn",
        "server-response-time": ["warn", {"minScore": 0.7}],
        "first-contentful-paint": ["warn", {"minScore": 0.7}],
        "largest-contentful-paint": ["warn", {"minScore": 0.25}],
        "total-blocking-time": ["warn", {"minScore": 0.7}],
        "cumulative-layout-shift": ["error", {"minScore": 0.9}],
        "speed-index": ["warn", {"minScore": 0.7}],
        "robots-txt": "error",
        "canonical": "error",
        "font-display": "warn",
        "viewport": "error",
        "aria-required-attr": "error",
        "aria-roles": "error",
        "doctype": "error",
        "charset": "error",
        "deprecations": "warn",
        "mainthread-work-breakdown": ["warn", {"minScore": 0.7}]
      }
    }
  }
}
